{

    "pythonVersion": "3.11", 

    "typeCheckingMode": "standard",

    "reportUnusedImport": false,

    "diagnosticSeverityOverrides": {
        "reportUnusedImport": "information"
    },

    "exclude": [
        "**/.*",
        "**/node_modules",
        "**/__pycache__",
        "**/venv*"
    ],
    "ignore": [
        "**/venv*"
    ]
}